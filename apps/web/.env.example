# Backend contract mode: fastapi | legacy
VITE_BACKEND_MODE=fastapi
VITE_ENABLE_ADMIN=false

# FastAPI backend (default)
VITE_API_URL=http://localhost:8000/api/v1
VITE_FASTAPI_URL=http://localhost:8000/api/v1

# Legacy Node/Express backend (optional)
VITE_LEGACY_API_URL=http://localhost:3000
VITE_LEGACY_PATIENT_ID=
VITE_LEGACY_DOCTOR_ID=

# Demo mapping for seeded FastAPI data
VITE_DEMO_PATIENT_ID=1
VITE_DEV_PATIENT_USER_ID=1
VITE_DEV_GUARDIAN_USER_ID=2
VITE_DEV_DOCTOR_USER_ID=3
VITE_DEV_ADMIN_USER_ID=4

# Auth0
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=replace_me
VITE_AUTH0_AUDIENCE=
VITE_AUTH0_SCOPE=openid profile email
VITE_AUTH0_ROLE_NAMESPACE=https://healthconnect.app
VITE_DEFAULT_USER_NAME=Sawaab
