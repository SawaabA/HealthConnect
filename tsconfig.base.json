{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@healthconnect/ui": ["packages/ui/src/index.ts"],
      "@healthconnect/ui/*": ["packages/ui/src/*"],
      "@healthconnect/types": ["packages/types/src/index.ts"],
      "@healthconnect/config": ["packages/config/src/index.ts"]
    }
  }
}
