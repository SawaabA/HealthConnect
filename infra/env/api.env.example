# Core
APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/healthconnect
DISABLE_AUTH=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.healthconnect.local
AUTH0_ISSUER=https://your-tenant.us.auth0.com/

# RBAC seed strategy
# Roles expected: patient, guardian, doctor, admin

# AI Provider
AI_PROVIDER=backboard
BACKBOARD_BASE_URL=https://api.backboard.io
BACKBOARD_API_KEY=replace_me

# TTS Provider
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=replace_me
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Storage Provider
STORAGE_PROVIDER=vultr
VULTR_OBJECT_STORAGE_ENDPOINT=https://ewr1.vultrobjects.com
VULTR_OBJECT_STORAGE_REGION=ewr1
VULTR_BUCKET_NAME=healthconnect-docs
VULTR_ACCESS_KEY=replace_me
VULTR_SECRET_KEY=replace_me
LOCAL_STORAGE_PATH=./generated-audio

# Tailscale (for private service communication)
TAILSCALE_AUTH_KEY=tskey-xxxx
