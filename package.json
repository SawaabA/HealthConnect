{
  "name": "healthconnect",
  "private": true,
  "version": "0.1.0",
  "description": "HealthConnect monorepo starter for consent-driven health data access",
  "scripts": {
    "dev": "docker compose -f infra/docker-compose.yml up --build",
    "dev:web": "npm --prefix apps/web run dev",
    "dev:api": "uvicorn app.main:app --app-dir apps/api --reload --host 0.0.0.0 --port 8000",
    "test:api": "pytest apps/api/tests",
    "lint:web": "npm --prefix apps/web run lint",
    "build:web": "npm --prefix apps/web run build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
